{
	"name": "personal-website",
	"type": "module",
	"version": "0.0.1",
	"engines": {
		"node": ">=22.12.0"
	},
	"scripts": {
		"dev": "astro dev",
		"build": "astro build",
		"preview": "astro preview",
		"astro": "astro",
		"lint": "eslint . --ext .js,.ts,.astro",
		"lint:fix": "eslint . --ext .js,.ts,.astro --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"prepare": "husky"
	},
	"dependencies": {
		"@astrojs/mdx": "^5.0.0",
		"@astrojs/rss": "^4.0.17",
		"@astrojs/sitemap": "^3.7.1",
		"astro": "^6.0.4",
		"sharp": "^0.34.3"
	},
	"devDependencies": {
		"@typescript-eslint/parser": "^8.58.1",
		"eslint": "^10.2.0",
		"eslint-plugin-astro": "^1.7.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"prettier": "^3.8.1",
		"prettier-plugin-astro": "^0.14.1",
		"typescript": "^5.9.3"
	},
	"lint-staged": {
		"*.{js,ts,astro}": [
			"eslint --fix",
			"prettier --write"
		],
		"*.{css,md,json}": [
			"prettier --write"
		]
	}
}
