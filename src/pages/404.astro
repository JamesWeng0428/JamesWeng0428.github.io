---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_TITLE } from '../consts';
---

<BaseLayout title={`404 | ${SITE_TITLE}`} description="Page not found">
	<main>
		<h1>404</h1>
		<p>Page not found</p>
		<p><a href="/">← Back to home</a></p>
	</main>
	<style>
		main {
			max-width: 720px;
			margin: 0 auto;
			padding: var(--space-xl) var(--space-sm);
			text-align: center;
		}
		h1 {
			font-size: 6rem;
			margin: 0;
			color: var(--ink-mute);
			line-height: 1;
		}
		p {
			font-size: 1.2rem;
			color: var(--ink-soft);
			margin: var(--space-md) 0;
		}
		a {
			color: var(--accent);
			text-decoration: none;
		}
		a:hover {
			text-decoration: underline;
		}
	</style>
</BaseLayout>
