---
import { getCollection } from 'astro:content';
import OGImage from '../../assets/blog-placeholder-about.jpg';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { fade } from 'astro:transitions';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout
	title={`Journals | ${SITE_TITLE}`}
	description="Personal journals and reflections by James Weng."
	image={OGImage}
>
	<main id="main-content" class="container" transition:animate={fade({ duration: '0.3s' })}>
		<div class="page-header">
			<h1>Journals</h1>
			<p class="page-subtitle">Personal reflections and thoughts.</p>
		</div>
		<section>
			<ul class="post-list">
				{
					posts.map((post) => (
						<li>
							<a href={`/blog/${post.id}/`}>
								<h4 class="title">{post.data.title}</h4>
								<p class="meta">
									<FormattedDate date={post.data.pubDate} />
								</p>
								<p class="excerpt">{post.data.description}</p>
							</a>
						</li>
					))
				}
			</ul>
		</section>
	</main>
	<style>
		.page-subtitle {
			color: var(--ink-mute);
			margin: 0;
			font-size: 1.15rem;
		}
		.post-list {
			list-style-type: none;
			margin: 0;
			padding: 0;
			display: flex;
			flex-direction: column;
			gap: 0;
		}
		.post-list li {
			border-top: 1px solid var(--rule-soft);
		}
		.post-list li:last-child {
			border-bottom: 1px solid var(--rule-soft);
		}
		.post-list li a {
			display: block;
			padding: var(--space-lg) 0;
			text-decoration: none;
			transition: padding 0.3s cubic-bezier(0.16, 1, 0.3, 1);
		}
		.post-list li a:hover {
			padding-left: 0.75rem;
		}
		.post-list li a:hover .title {
			color: var(--accent);
		}
		.title {
			margin: 0 0 0.35rem;
			color: var(--ink);
			line-height: 1.25;
			font-size: 1.35rem;
			font-weight: 600;
			letter-spacing: -0.01em;
			transition: color 0.2s;
		}
		.meta {
			margin: 0;
			color: var(--ink-mute);
			font-size: 0.9rem;
			font-weight: 500;
		}
		.excerpt {
			margin: 0.5rem 0 0;
			font-size: 1rem;
			color: var(--ink-soft);
			line-height: 1.6;
			max-width: 620px;
		}
		@media (max-width: 720px) {
			.title {
				font-size: 1.15rem;
			}
		}
	</style>
</BaseLayout>
