---
import SectionHead from './SectionHead.astro';
import FormattedDate from './FormattedDate.astro';
import { t, type Lang } from '../i18n';

interface Props {
	posts: any[];
	lang?: Lang;
}
const { posts, lang = 'en' } = Astro.props;
const c = t[lang].writing;

// Rough read-time estimate. Swap for a real reading-time lib if you prefer.
function readTime(body: string | undefined) {
	if (!body) return `3 ${c.minSuffix}`;
	const words = body.split(/\s+/).length;
	return `${Math.max(1, Math.round(words / 220))} ${c.minSuffix}`;
}
---

<section id="writing">
	<div class="wrap">
		<SectionHead num={c.sectionNum} title={c.sectionTitle} titleEm={c.sectionTitleEm} />
		<div class="writing">
			{
				posts.map((p) => (
					<a class="post-row" href={`/blog/${p.id}/`}>
						<span class="date">
							<FormattedDate date={p.data.pubDate} />
						</span>
						<div>
							<div class="title">{p.data.title}</div>
							<p class="desc">{p.data.description}</p>
						</div>
						<span class="read">{readTime(p.body)}</span>
					</a>
				))
			}
		</div>
	</div>
</section>
