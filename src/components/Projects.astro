---
import SectionHead from './SectionHead.astro';
import { projects } from '../data/projects';
---

<section id="projects">
	<div class="wrap">
		<SectionHead num="§ 04 / Projects" title="Selected" titleEm="work." />
		<div class="projects">
			{
				projects.map((p) => {
					const inner = (
						<>
							<div class="project-head">
								<h3 class="project-title">{p.title}</h3>
								<span class="project-year">{p.year}</span>
							</div>
							<p class="project-desc">{p.desc}</p>
							<div class="project-tags">
								{p.tags.map((t) => (
									<span>{t}</span>
								))}
							</div>
						</>
					);
					return (
						<article class="project">
							{p.url ? (
								<a href={p.url} target="_blank" rel="noopener noreferrer" class="project-link">
									{inner}
								</a>
							) : (
								inner
							)}
						</article>
					);
				})
			}
		</div>
	</div>
</section>

<style>
	.project-link {
		color: inherit;
		text-decoration: none;
		display: block;
	}
</style>
