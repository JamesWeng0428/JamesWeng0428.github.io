---
// src/components/Hero.astro
import { t, type Lang, sectionHref } from '../i18n';

interface Props {
	lang?: Lang;
}
const { lang = 'en' } = Astro.props;
const c = t[lang].hero;
---

<div class="wrap hero" data-hero-variant="editorial">
	<div class="hero-layout">
		<div class="hero-copy">
			<div class="fade-up">
				<span class="eyebrow">{c.eyebrow}</span>
			</div>
			<h1 class="hero-display fade-up d1">
				{c.titleLine1}<br />
				<em>{c.titleLine2Em}</em>
			</h1>
			<p class="hero-lede fade-up d2">
				{c.lede}
			</p>
			<div class="fade-up d3" style="display: flex; gap: 0.75rem; flex-wrap: wrap;">
				<a class="btn" href={sectionHref(lang, 'contact')}>
					{c.ctaPrimary}
					<span class="btn-arrow">→</span>
				</a>
				<a class="btn btn-ghost" href={sectionHref(lang, 'projects')}>{c.ctaSecondary}</a>
			</div>
		</div>
		<div class="hero-avatar fade-up d2">
			<img src="/avatar.png" alt="James Weng" />
		</div>
	</div>
	<div class="hero-meta fade-up d4">
		<div class="hero-meta-item">
			<span class="k">{c.metaBasedInK}</span>
			<span class="v">{c.metaBasedInV}</span>
		</div>
		<div class="hero-meta-item">
			<span class="k">{c.metaFocusK}</span>
			<span class="v">{c.metaFocusV}</span>
		</div>
		<div class="hero-meta-item">
			<span class="k">{c.metaStatusK}</span>
			<span class="v">{c.metaStatusV}</span>
		</div>
	</div>
</div>

<style>
	.hero-layout {
		display: grid;
		grid-template-columns: 1fr auto;
		gap: 3rem;
		align-items: center;
		margin-bottom: 3rem;
	}
	.hero-avatar {
		width: 180px;
		height: 180px;
		border-radius: 50%;
		overflow: hidden;
		border: 1px solid var(--rule-soft);
		flex-shrink: 0;
	}
	.hero-avatar img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}
	@media (max-width: 680px) {
		.hero-layout {
			grid-template-columns: 1fr;
			gap: 2rem;
		}
		.hero-avatar {
			width: 140px;
			height: 140px;
			order: -1;
		}
	}
</style>
