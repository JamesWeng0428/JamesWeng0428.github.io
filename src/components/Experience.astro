---
import SectionHead from './SectionHead.astro';
import { t, type Lang } from '../i18n';

interface Props {
	lang?: Lang;
}
const { lang = 'en' } = Astro.props;
const c = t[lang].experience;
---

<section id="work">
	<div class="wrap">
		<SectionHead num={c.sectionNum} title={c.sectionTitle} titleEm={c.sectionTitleEm} />
		<div class="exp">
			{
				c.items.map((e) => (
					<div class="exp-row">
						<span class="years">{e.years}</span>
						<div class="body">
							<div class="role">{e.role}</div>
							<div class="co">
								{e.co} <em>· {e.coNote}</em>
							</div>
							<p class="exp-detail">{e.detail}</p>
							<div class="exp-stack">
								{e.stack.map((s) => (
									<span>{s}</span>
								))}
							</div>
						</div>
						<span class="loc">{e.loc}</span>
					</div>
				))
			}
		</div>
	</div>
</section>
