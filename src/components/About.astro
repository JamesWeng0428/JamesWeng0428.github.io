---
import SectionHead from './SectionHead.astro';
import { t, type Lang, sectionHref } from '../i18n';

interface Props {
	lang?: Lang;
}
const { lang = 'en' } = Astro.props;
const c = t[lang].about;
---

<section id="about">
	<div class="wrap">
		<SectionHead num={c.sectionNum} title={c.sectionTitle} titleEm={c.sectionTitleEm} />
		<div class="about-grid">
			<aside class="about-side">
				<div class="about-side-block">
					<span class="k">{c.sideNowK}</span>
					<span class="v"
						>{c.sideNowV1}<a href={sectionHref(lang, 'work')}>{c.sideNowLink}</a>{c.sideNowV2}</span
					>
				</div>
				<div class="about-side-block">
					<span class="k">{c.sideHobbiesK}</span>
					<div class="v-list">
						{c.sideHobbies.map((h) => <span>{h}</span>)}
					</div>
				</div>
				<div class="about-side-block">
					<span class="k">{c.sideLanguagesK}</span>
					<div class="v-list">
						{c.sideLanguages.map((l) => <span>{l}</span>)}
					</div>
				</div>
			</aside>
			<div class="about-body">
				<p>
					{c.body1Pre}<strong>{c.body1Strong}</strong>{c.body1Post}
				</p>
				<p>
					{c.body2Pre}<strong>{c.body2Strong}</strong>{c.body2Post}
				</p>
				<p>
					{c.body3Pre}<strong>{c.body3Strong}</strong>{c.body3Post}
				</p>
			</div>
		</div>
	</div>
</section>
