---
import SectionHead from './SectionHead.astro';
import { boulderingMedia, cyclingMedia } from '../data/hobbies';
import { t, type Lang } from '../i18n';

interface Props {
	lang?: Lang;
}
const { lang = 'en' } = Astro.props;
const c = t[lang].hobbies;
---

<section id="hobbies">
	<div class="wrap">
		<SectionHead num={c.sectionNum} title={c.sectionTitle} titleEm={c.sectionTitleEm} />

		<div class="hobby-block">
			<div class="hobby-head">
				<h3 class="hobby-title">{c.boulderTitle}</h3>
			</div>
			<p class="hobby-desc">
				{c.boulderDescPre}<a
					href="https://www.urbanaboulders.com/"
					target="_blank"
					rel="noopener noreferrer">{c.boulderGymsLink}</a
				>{c.boulderDescMid}<a
					href="https://www.instagram.com/jamesweng0428/"
					target="_blank"
					rel="noopener noreferrer">{c.boulderIgLink}</a
				>{c.boulderDescEnd}
			</p>
			<div class="gallery gallery-videos">
				{
					boulderingMedia.map((m) => (
						<div class="gallery-item gallery-video">
							<video controls playsinline preload="none" poster={m.poster}>
								<source src={m.src} type="video/mp4" />
							</video>
						</div>
					))
				}
			</div>
			<div class="hobby-stats">
				{
					c.boulderStats.map((s) => (
						<span>
							{s.label} · <b>{s.value}</b>
						</span>
					))
				}
			</div>
		</div>

		<div class="hobby-block">
			<div class="hobby-head">
				<h3 class="hobby-title">{c.cyclingTitle}</h3>
				<span class="hobby-label">{c.cyclingLabel}</span>
			</div>
			<p class="hobby-desc">
				{c.cyclingDescPre}<a
					href="https://www.strava.com/athletes/124960807"
					target="_blank"
					rel="noopener noreferrer">{c.cyclingStravaLink}</a
				>{c.cyclingDescEnd}
			</p>
			<div class="gallery gallery-photos">
				{
					cyclingMedia.map((m) => (
						<div class="gallery-item gallery-photo">
							<img src={m.src} alt={m.alt} loading="lazy" />
						</div>
					))
				}
			</div>
			<div class="hobby-stats">
				{
					c.cyclingStats.map((s) => (
						<span>
							{s.label} · <b>{s.value}</b>
						</span>
					))
				}
			</div>
		</div>
	</div>
</section>

<style>
	.hobby-block {
		display: grid;
		gap: 1rem;
		padding: 2rem 0;
		border-bottom: 1px solid var(--rule-soft);
	}
	.hobby-block:last-of-type {
		border-bottom: none;
	}
	.hobby-block .hobby-head {
		border-top: none;
		padding-top: 0;
	}
	.hobby-block .hobby-title {
		padding-top: 0;
	}
	.hobby-block .hobby-label {
		padding-top: 0.4rem;
	}

	.gallery {
		display: grid;
		gap: 1rem;
	}
	.gallery-videos {
		grid-template-columns: repeat(2, minmax(0, 1fr));
	}
	.gallery-photos {
		grid-template-columns: repeat(3, minmax(0, 1fr));
	}

	.gallery-item {
		border: 1px solid var(--rule);
		border-radius: 4px;
		overflow: hidden;
		background: var(--bg-raised);
	}
	.gallery-video {
		aspect-ratio: 9 / 16;
		display: flex;
		align-items: center;
		justify-content: center;
	}
	.gallery-video video {
		width: 100%;
		height: 100%;
		object-fit: contain;
		background: oklch(0% 0 0);
		display: block;
	}
	.gallery-photo {
		aspect-ratio: 4 / 3;
	}
	.gallery-photo img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	@media (max-width: 680px) {
		.gallery-videos,
		.gallery-photos {
			grid-template-columns: 1fr;
		}
	}
</style>
