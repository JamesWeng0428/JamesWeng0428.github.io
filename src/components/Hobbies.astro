---
import SectionHead from './SectionHead.astro';
import { boulderingMedia, cyclingMedia, boulderingStats, cyclingStats } from '../data/hobbies';
---

<section id="hobbies">
	<div class="wrap">
		<SectionHead num="§ 02 / Hobbies" title="Off the" titleEm="keyboard." />

		<div class="hobby-block">
			<div class="hobby-head">
				<h3 class="hobby-title">Bouldering</h3>
			</div>
			<p class="hobby-desc">
				I'm not a nerd! I have hobbies away from my computer. Bouldering is one of them. I'm an
				active climber at <a
					href="https://www.urbanaboulders.com/"
					target="_blank"
					rel="noopener noreferrer">Urbana Boulders and Boneyard Boulders</a
				>
				. If you are interested in Climbing, find me on
				<a href="https://www.instagram.com/jamesweng0428/" target="_blank" rel="noopener noreferrer"
					>Instagram</a
				>!
			</p>
			<div class="gallery gallery-videos">
				{
					boulderingMedia.map((m) => (
						<div class="gallery-item gallery-video">
							<video controls playsinline preload="none" poster={m.poster}>
								<source src={m.src} type="video/mp4" />
							</video>
						</div>
					))
				}
			</div>
			<div class="hobby-stats">
				{
					boulderingStats.map((s) => (
						<span>
							{s.label} · <b>{s.value}</b>
						</span>
					))
				}
			</div>
		</div>

		<div class="hobby-block">
			<div class="hobby-head">
				<h3 class="hobby-title">Cycling</h3>
				<span class="hobby-label">On the road</span>
			</div>
			<p class="hobby-desc">
				I also love cycling and have a GIANT Propel ADV SL. If you love ride too, find me on <a
					href="https://www.strava.com/athletes/124960807"
					target="_blank"
					rel="noopener noreferrer">Strava</a
				>!
			</p>
			<div class="gallery gallery-photos">
				{
					cyclingMedia.map((m) => (
						<div class="gallery-item gallery-photo">
							<img src={m.src} alt={m.alt} loading="lazy" />
						</div>
					))
				}
			</div>
			<div class="hobby-stats">
				{
					cyclingStats.map((s) => (
						<span>
							{s.label} · <b>{s.value}</b>
						</span>
					))
				}
			</div>
		</div>
	</div>
</section>

<style>
	.hobby-block {
		display: grid;
		gap: 1rem;
		padding: 2rem 0;
		border-bottom: 1px solid var(--rule-soft);
	}
	.hobby-block:last-of-type {
		border-bottom: none;
	}
	.hobby-block .hobby-head {
		border-top: none;
		padding-top: 0;
	}
	.hobby-block .hobby-title {
		padding-top: 0;
	}
	.hobby-block .hobby-label {
		padding-top: 0.4rem;
	}

	.gallery {
		display: grid;
		gap: 1rem;
	}
	.gallery-videos {
		grid-template-columns: repeat(2, minmax(0, 1fr));
	}
	.gallery-photos {
		grid-template-columns: repeat(3, minmax(0, 1fr));
	}

	.gallery-item {
		border: 1px solid var(--rule);
		border-radius: 4px;
		overflow: hidden;
		background: var(--bg-raised);
	}
	.gallery-video {
		aspect-ratio: 9 / 16;
		display: flex;
		align-items: center;
		justify-content: center;
	}
	.gallery-video video {
		width: 100%;
		height: 100%;
		object-fit: contain;
		background: oklch(0% 0 0);
		display: block;
	}
	.gallery-photo {
		aspect-ratio: 4 / 3;
	}
	.gallery-photo img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	@media (max-width: 680px) {
		.gallery-videos,
		.gallery-photos {
			grid-template-columns: 1fr;
		}
	}
</style>
