---
import SectionHead from './SectionHead.astro';
import { t, type Lang } from '../i18n';

interface Props {
	lang?: Lang;
}
const { lang = 'en' } = Astro.props;
const c = t[lang].contact;
const year = new Date().getFullYear();
---

<section id="contact" style="border-bottom: none;">
	<div class="wrap contact">
		<SectionHead num={c.sectionNum} title={c.sectionTitle} titleEm={c.sectionTitleEm} />
		<div class="contact-inner">
			<div class="contact-links">
				{
					c.items.map((item) => (
						<a
							class="contact-link"
							href={item.href}
							target={item.href.startsWith('http') ? '_blank' : undefined}
							rel={item.href.startsWith('http') ? 'noopener noreferrer' : undefined}
						>
							<span class="k">{item.k}</span>
							<span class="v">{item.v}</span>
							<span class="arr">↗</span>
						</a>
					))
				}
			</div>
		</div>
		<footer>
			<span>© James Weng — {year}</span>
			<span>{c.footerLoc}</span>
		</footer>
	</div>
</section>
