---
import type { CollectionEntry } from 'astro:content';
import { fade } from 'astro:transitions';
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';

type BlogData = CollectionEntry<'blog'>['data'];

interface Props extends BlogData {
	prevPost?: { id: string; title: string } | null;
	nextPost?: { id: string; title: string } | null;
}

const { title, description, pubDate, updatedDate, prevPost, nextPost } = Astro.props;
---

<BaseLayout {title} {description}>
	<div class="reading-progress" id="reading-progress"></div>
	<main id="main-content" transition:animate={fade({ duration: '0.3s' })}>
		<article>
			<div class="prose">
				<div class="title">
					<div class="date">
						<FormattedDate date={pubDate} />
						{
							updatedDate && (
								<div class="last-updated-on">
									Last updated on <FormattedDate date={updatedDate} />
								</div>
							)
						}
					</div>
					<h1>{title}</h1>
					<hr />
				</div>
				<slot />
				{
					(prevPost || nextPost) && (
						<nav class="post-nav">
							{prevPost ? (
								<a href={`/blog/${prevPost.id}/`}>
									<span class="post-nav-label">Previous</span>
									<span class="post-nav-title">{prevPost.title}</span>
								</a>
							) : (
								<div />
							)}
							{nextPost ? (
								<a href={`/blog/${nextPost.id}/`} class="next">
									<span class="post-nav-label">Next</span>
									<span class="post-nav-title">{nextPost.title}</span>
								</a>
							) : (
								<div />
							)}
						</nav>
					)
				}
			</div>
		</article>
	</main>
	<style>
		.reading-progress {
			position: fixed;
			top: 0;
			left: 0;
			width: 0%;
			height: 2px;
			background: var(--accent);
			z-index: 200;
			transition: width 0.1s linear;
		}
		main {
			width: calc(100% - 2em);
			max-width: 100%;
			margin: 0;
		}
		.prose {
			width: 720px;
			max-width: calc(100% - 2em);
			margin: auto;
			padding: var(--space-xl) 1em;
			color: var(--ink-soft);
			font-size: 1.08rem;
			line-height: 1.85;
		}
		.title {
			margin-bottom: var(--space-xl);
			padding: var(--space-lg) 0 var(--space-md);
			text-align: left;
			line-height: 1;
		}
		.title h1 {
			margin: 0 0 0.4em 0;
			font-size: clamp(2rem, 6vw, 3rem);
			letter-spacing: -0.02em;
			line-height: 1.1;
		}
		.date {
			margin-bottom: 0.5em;
			color: var(--ink-mute);
			font-size: 0.95rem;
		}
		.last-updated-on {
			font-style: italic;
		}
		.post-nav {
			display: flex;
			justify-content: space-between;
			gap: 1rem;
			margin-top: var(--space-xl);
			padding-top: var(--space-lg);
			border-top: 1px solid var(--rule);
		}
		.post-nav a {
			display: flex;
			flex-direction: column;
			gap: 0.3rem;
			text-decoration: none;
			max-width: 45%;
			padding: 0.75rem 1rem;
			border-radius: 6px;
			transition: background 0.2s;
		}
		.post-nav a:hover {
			background: var(--bg-raised);
		}
		.post-nav a:hover .post-nav-title {
			color: var(--accent);
		}
		.post-nav-label {
			font-size: 0.75rem;
			color: var(--ink-mute);
			text-transform: uppercase;
			letter-spacing: 0.06em;
			font-weight: 600;
		}
		.post-nav-title {
			font-size: 0.95rem;
			color: var(--ink);
			font-weight: 600;
			transition: color 0.2s;
		}
		.post-nav .next {
			text-align: right;
			margin-left: auto;
		}
		@media (max-width: 560px) {
			.post-nav {
				flex-direction: column;
				gap: 0.75rem;
			}
			.post-nav a {
				max-width: 100%;
			}
			.post-nav .next {
				text-align: left;
				margin-left: 0;
			}
		}
	</style>
	<script>
		document.addEventListener('astro:page-load', () => {
			const scopedWindow = window as Window & {
				__blogPostController?: AbortController;
			};
			scopedWindow.__blogPostController?.abort();
			const controller = new AbortController();
			const { signal } = controller;
			scopedWindow.__blogPostController = controller;

			const bar = document.getElementById('reading-progress');
			if (!bar) return;
			const update = () => {
				const scrollTop = window.scrollY;
				const docHeight = document.documentElement.scrollHeight - window.innerHeight;
				const progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
				bar.style.width = `${Math.min(progress, 100)}%`;
			};
			window.addEventListener('scroll', update, { passive: true, signal });
			update();
		});
	</script>
</BaseLayout>
